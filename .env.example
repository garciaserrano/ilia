# Ilia - Gym Progress Tracker
# Copy this file to .env and fill in your real Google Sheet values.

# Option 1:
# Use the full public Google Sheet CSV URL.
# Recommended if you already have a published/export URL.
#
# Example:
# VITE_GOOGLE_SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/export?format=csv&gid=0"

VITE_GOOGLE_SHEET_CSV_URL=""

# Option 2:
# Use Google Sheet ID and GID.
#
# Example Google Sheet URL:
# https://docs.google.com/spreadsheets/d/1abcDEFghiJKL1234567890/edit#gid=0
#
# Sheet ID:
# 1abcDEFghiJKL1234567890
#
# GID:
# 0

VITE_GOOGLE_SHEET_ID=""
VITE_GOOGLE_SHEET_GID="0"
